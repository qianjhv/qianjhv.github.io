---
import { ViewTransitions } from 'astro:transitions'

import Header from '../components/Header.astro'
import '../styles/global.css'

const { class: className, pageTitle, linkHref } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href={linkHref} type="image/x-icon">
    <title>{pageTitle}</title>
    <ViewTransitions />
</head>
<body class="dark:bg-middark">
    <div class="container md:max-w-3xl mx-auto px-2 font-sans">
        <Header />
        <slot />
    </div>

</body>
</html>